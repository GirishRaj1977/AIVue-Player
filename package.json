{
  "name": "aivue-player",
  "version": "1.0.2",
  "description": "Python Electron IPTV Player",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "keywords": [],
  "author": "My Name",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.3.2",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "express": "^4.22.2",
    "sax": "^1.6.0",
    "sql.js": "^1.14.1",
    "sqlite3": "^6.0.1"
  },
  "build": {
    "appId": "com.aivue.player",
    "productName": "AIVue Player",
    "asar": true,
    "icon": "assets/logo.ico",
    "extraResources": [
      "bin/**/*",
      "backend/**/*"
    ],
    "files": [
      "**/*",
      "!node_modules/.package-lock.json",
      "!.gitignore",
      "!.gitattributes",
      "!.lean_ai/**/*",
      "!README.md",
      "!newfeat.txt",
      "!parser.spec",
      "!screenshots/**/*",
      "!dist/**/*",
      "!build/**/*",
      "!**/*.log",
      "!**/*.db",
      "!**/*.db-wal",
      "!**/*.db-shm",
      "!assets/open-epg.xml",
      "!assets/**/*.gz",
      "!assets/**/*.m3u",
      "!assets/**/*.m3u8",
      "!cache/**/*",
      "!ChannelLogos/**/*",
      "!AIVueRecordings/**/*",
      "!saved_channels.json",
      "!tmdb_config.json",
      "!remote_settings.json",
      "!**/__pycache__/**/*",
      "!**/*.pyc",
      "!**/*.pyo"
    ]
  }
}

